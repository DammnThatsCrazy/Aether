# =============================================================================
# Aether Platform — Environment Variables
#
# Copy to .env and customize for your environment:
#   cp .env.example .env
#
# All variables have sensible defaults for local development.
# Variables marked [REQUIRED IN PRODUCTION] must be set for non-local envs.
# =============================================================================

# === General ===
AETHER_ENV=local                       # local | dev | staging | production
DEBUG=true

# === Database — PostgreSQL (asyncpg) ===
# DATABASE_URL is the primary connection string used by repositories.
# Individual TSDB_* vars are kept for backward compatibility with deployment scripts.
DATABASE_URL=                            # [REQUIRED IN PRODUCTION] e.g. postgresql://aether:pass@db:5432/aether
TSDB_HOST=localhost
TSDB_PORT=5432
TSDB_DATABASE=aether
TSDB_USER=aether
TSDB_PASSWORD=                          # [REQUIRED IN PRODUCTION]
TSDB_POOL_MIN=5
TSDB_POOL_MAX=20

# === Database — Amazon Neptune (Graph) ===
NEPTUNE_ENDPOINT=localhost
NEPTUNE_PORT=8182
AWS_REGION=us-east-1

# === Cache — Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# === Database — DynamoDB ===
DYNAMODB_ENDPOINT=                      # Leave empty for AWS; set for local DynamoDB
DYNAMODB_TABLE_PREFIX=aether_

# === Database — OpenSearch ===
OPENSEARCH_ENDPOINT=localhost
OPENSEARCH_PORT=9200

# === Event Bus — Kafka / SNS+SQS ===
EVENT_BROKER=kafka                      # kafka | sns_sqs
KAFKA_BOOTSTRAP_SERVERS=localhost:9092   # [REQUIRED IN PRODUCTION] Used by aiokafka producer/consumer
KAFKA_BROKERS=localhost:9092            # Legacy alias
KAFKA_CONSUMER_GROUP=aether-backend
SNS_TOPIC_ARN=
SQS_QUEUE_URL=

# === API Configuration ===
CORS_ORIGINS=http://localhost:3000,https://app.aether.io
MAX_REQUEST_BODY_MB=10

# === Authentication ===
JWT_SECRET=change-me-in-production      # [REQUIRED IN PRODUCTION]
JWT_EXPIRY_MINUTES=60

# === Intelligence Graph Feature Flags ===
IG_AGENT_LAYER=false
IG_COMMERCE_LAYER=false
IG_X402_LAYER=false
IG_ONCHAIN_LAYER=false
IG_TRUST_SCORING=false
IG_BYTECODE_RISK=false
IG_RPC_GATEWAY=false

# === QuickNode (Blockchain RPC) ===
QUICKNODE_API_KEY=
QUICKNODE_ENDPOINT=
QUICKNODE_X402_ENABLED=false
QUICKNODE_MAX_RPS=100

# === Provider Gateway ===
PROVIDER_GATEWAY_ENABLED=false
BYOK_ENCRYPTION_KEY=                    # [REQUIRED IN PRODUCTION] Fernet key for BYOK vault (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PROVIDER_GATEWAY_ENCRYPTION_KEY=        # Legacy alias for BYOK_ENCRYPTION_KEY
ALCHEMY_API_KEY=
ALCHEMY_ENDPOINT=
INFURA_API_KEY=
INFURA_PROJECT_ID=
ETHERSCAN_API_KEY=
MORALIS_API_KEY=
PROVIDER_MAX_RETRIES=2
PROVIDER_CB_THRESHOLD=5
PROVIDER_CB_TIMEOUT_S=30
PROVIDER_METER_FLUSH_S=60

# === Model Extraction Defense ===
ENABLE_EXTRACTION_DEFENSE=false
ENABLE_OUTPUT_NOISE=true
ENABLE_WATERMARK=true
ENABLE_QUERY_ANALYSIS=true
WATERMARK_SECRET_KEY=aether-wm-default-change-me   # [REQUIRED IN PRODUCTION]
CANARY_SECRET_SEED=aether-canary-seed-change-me     # [REQUIRED IN PRODUCTION]
EXTRACTION_KEY_RPM=60
EXTRACTION_KEY_RPH=1000
EXTRACTION_KEY_RPD=10000
EXTRACTION_IP_RPM=120
EXTRACTION_IP_RPH=3000
EXTRACTION_IP_RPD=30000
EXTRACTION_NOISE_STD=0.02
EXTRACTION_OUTPUT_PRECISION=2

# === GeoIP Enrichment (MaxMind GeoLite2) ===
GEOIP_DB_PATH=/usr/share/GeoIP/GeoLite2-City.mmdb
GEOIP_ASN_DB_PATH=/usr/share/GeoIP/GeoLite2-ASN.mmdb

# === Agent Layer ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=8

# === ML Serving ===
ML_SERVING_URL=http://localhost:8080

# === Data Ingestion (Node.js) ===
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
BATCH_SIZE=500
MAX_EVENT_SIZE_KB=32

# === Social API Keys (Agent Workers) ===
TWITTER_BEARER_TOKEN=
DISCORD_BOT_TOKEN=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
