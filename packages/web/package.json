{
  "name": "@aether/web",
  "version": "8.8.0",
  "description": "Aether SDK for Web \u2014 Behavioral analytics with thin-client architecture",
  "main": "dist/aether.cjs.js",
  "module": "dist/aether.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/aether.esm.js",
      "require": "./dist/aether.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --fix"
  },
  "sideEffects": false,
  "license": "UNLICENSED"
}
